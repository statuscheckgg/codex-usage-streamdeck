{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Actions": [
    {
      "Icon": "imgs/action-icon",
      "Name": "Codex Usage",
      "States": [
        {
          "Image": "imgs/action-default",
          "TitleAlignment": "middle",
          "FontSize": 10
        }
      ],
      "Tooltip": "Show Codex 5-hour and weekly usage limits.",
      "UUID": "com.statuscheck.codex-usage.usage",
      "PropertyInspectorPath": "ui/usage.html",
      "SupportURL": "https://github.com/statuscheckgg/codex-usage-streamdeck/issues",
      "UserTitleEnabled": false,
      "SupportedInMultiActions": false
    }
  ],
  "Author": "Status Check",
  "Category": "Codex Usage Monitor",
  "CategoryIcon": "imgs/category-icon",
  "CodePath": "bin/plugin.js",
  "Description": "Unofficial local Codex usage monitor for Stream Deck. Displays 5-hour, weekly, credit, and optional model-specific usage from the local Codex login.",
  "Icon": "imgs/plugin-icon",
  "Name": "Codex Usage Monitor",
  "Nodejs": {
    "Version": "24"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "mac",
      "MinimumVersion": "13"
    }
  ],
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "7.1"
  },
  "SupportURL": "https://github.com/statuscheckgg/codex-usage-streamdeck/issues",
  "URL": "https://github.com/statuscheckgg/codex-usage-streamdeck",
  "UUID": "com.statuscheck.codex-usage",
  "Version": "0.1.2.0"
}