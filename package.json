{
  "name": "codex-usage-streamdeck",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial local Codex usage monitor for Elgato Stream Deck.",
  "homepage": "https://github.com/statuscheckgg/codex-usage-streamdeck",
  "repository": {
    "type": "git",
    "url": "https://github.com/statuscheckgg/codex-usage-streamdeck.git"
  },
  "bugs": {
    "url": "https://github.com/statuscheckgg/codex-usage-streamdeck/issues"
  },
  "scripts": {
    "check": "node --check com.statuscheck.codex-usage.sdPlugin/bin/plugin.js",
    "test:harness": "node scripts/test-plugin-harness.mjs",
    "validate": "streamdeck validate com.statuscheck.codex-usage.sdPlugin",
    "pack": "streamdeck pack -f com.statuscheck.codex-usage.sdPlugin"
  },
  "keywords": [
    "streamdeck",
    "codex",
    "openai",
    "usage"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "ws": "^8.20.0"
  }
}
